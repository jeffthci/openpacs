# Copy this to .env and fill in your values
DATABASE_URL=postgresql://pacs:CHANGE_ME@db:5432/pacsdb
POSTGRES_DB=pacsdb
POSTGRES_USER=pacs
POSTGRES_PASSWORD=CHANGE_ME

SECRET_KEY=CHANGE_ME_32_CHAR_MIN
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

AE_TITLE=OPENPACS
DICOM_PORT=11112
DICOM_STORAGE_PATH=/opt/pacs/storage
DICOM_STAGING_PATH=/opt/pacs/staging

WADO_BASE_URL=http://YOUR_SERVER_IP:8000
REDIS_URL=redis://redis:6379/0
DUPLICATE_SOP_POLICY=ignore

CORS_ORIGINS=http://localhost:8080,http://YOUR_SERVER_IP:8080
VITE_API_URL=http://YOUR_SERVER_IP:8000
VITE_OHIF_URL=http://YOUR_SERVER_IP:3000
